        {
          "path": "registry/neonfin/components/neonfin/wallet-qr-code.tsx",
          "type": "registry:component",
          "target": "components/neonfin/wallet-qr-code.tsx"
        },
        {
          "path": "registry/neonfin/components/neonfin/wallet-qr-scanner.tsx",
          "type": "registry:component",
