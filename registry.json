{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "pay",
  "homepage": "https://pay.vantezzen.io",
  "items": [
    {
      "name": "pay-client",
      "type": "registry:lib",
      "title": "vantezzen/pay client",
      "description": "Zero-dependency typed client for the vantezzen/pay API (credits, checkout, credit-code storage).",
      "files": [
        {
          "path": "registry/pay/lib/pay/error.ts",
          "type": "registry:lib",
          "target": "lib/pay/error.ts"
        },
        {
          "path": "registry/pay/lib/pay/index.ts",
          "type": "registry:lib",
          "target": "lib/pay/index.ts"
        },
        {
          "path": "registry/pay/lib/pay/format.ts",
          "type": "registry:lib",
          "target": "lib/pay/format.ts"
        },
        {
          "path": "registry/pay/lib/pay/popup.ts",
          "type": "registry:lib",
          "target": "lib/pay/popup.ts"
        }
      ]
    },
    {
      "name": "pay-server",
      "type": "registry:lib",
      "title": "vantezzen/pay server client",
      "description": "Zero-dependency server-only client for external-auth apps: get-or-create wallets by your user id and grant credits with a secret key.",
      "files": [
        {
          "path": "registry/pay/lib/pay/error.ts",
          "type": "registry:lib",
          "target": "lib/pay/error.ts"
        },
        {
          "path": "registry/pay/lib/pay/server.ts",
          "type": "registry:lib",
          "target": "lib/pay/server.ts"
        }
      ]
    },
    {
      "name": "pay-provider",
      "type": "registry:component",
      "title": "vantezzen/pay provider",
      "description": "PayProvider context + useCredits() / usePay() hooks. Required by all vantezzen/pay components.",
      "registryDependencies": ["https://pay.vantezzen.io/r/pay-client.json"],
      "files": [
        {
          "path": "registry/pay/components/pay/provider.tsx",
          "type": "registry:component",
          "target": "components/pay/provider.tsx"
        }
      ]
    },
    {
      "name": "pay-credits",
      "type": "registry:component",
      "title": "Remaining credits",
      "description": "Inline display of the current credit balance.",
      "registryDependencies": ["https://pay.vantezzen.io/r/pay-provider.json"],
      "files": [
        {
          "path": "registry/pay/components/pay/remaining-credits.tsx",
          "type": "registry:component",
          "target": "components/pay/remaining-credits.tsx"
        }
      ]
    },
    {
      "name": "pay-wallet",
      "type": "registry:component",
      "title": "Wallet button",
      "description": "Wallet button and dialog for copying, restoring, QR transfer, native QR scanning, and billing management.",
      "registryDependencies": [
        "dialog",
        "button",
        "input",
        "https://pay.vantezzen.io/r/pay-provider.json"
      ],
      "dependencies": ["lucide-react"],
      "files": [
        {
          "path": "registry/pay/components/pay/wallet-button.tsx",
          "type": "registry:component",
          "target": "components/pay/wallet-button.tsx"
        },
        {
          "path": "registry/pay/components/pay/wallet-dialog.tsx",
          "type": "registry:component",
          "target": "components/pay/wallet-dialog.tsx"
        },
        {
          "path": "registry/pay/components/pay/wallet-code-field.tsx",
          "type": "registry:component",
          "target": "components/pay/wallet-code-field.tsx"
        },
        {
          "path": "registry/pay/components/pay/wallet-qr-code.tsx",
          "type": "registry:component",
          "target": "components/pay/wallet-qr-code.tsx"
        },
        {
          "path": "registry/pay/components/pay/wallet-qr-scanner.tsx",
          "type": "registry:component",
          "target": "components/pay/wallet-qr-scanner.tsx"
        },
        {
          "path": "registry/pay/lib/pay/qr.ts",
          "type": "registry:lib",
          "target": "lib/pay/qr.ts"
        }
      ]
    },
    {
      "name": "pay-purchase",
      "type": "registry:component",
      "title": "Purchase dialog",
      "description": "PurchaseButton + PurchaseDialog: list prices and start popup or redirect checkout.",
      "registryDependencies": [
        "dialog",
        "button",
        "https://pay.vantezzen.io/r/pay-provider.json"
      ],
      "dependencies": ["lucide-react"],
      "files": [
        {
          "path": "registry/pay/components/pay/purchase-dialog.tsx",
          "type": "registry:component",
          "target": "components/pay/purchase-dialog.tsx"
        }
      ]
    },
    {
      "name": "pay-gate",
      "type": "registry:component",
      "title": "Credit & feature gates",
      "description": "Gate content on having enough credits (CreditGate) or an unlocked feature (FeatureGate), with a purchase fallback.",
      "registryDependencies": [
        "https://pay.vantezzen.io/r/pay-provider.json",
        "https://pay.vantezzen.io/r/pay-purchase.json"
      ],
      "dependencies": ["lucide-react"],
      "files": [
        {
          "path": "registry/pay/components/pay/credit-gate.tsx",
          "type": "registry:component",
          "target": "components/pay/credit-gate.tsx"
        },
        {
          "path": "registry/pay/components/pay/feature-gate.tsx",
          "type": "registry:component",
          "target": "components/pay/feature-gate.tsx"
        }
      ]
    }
  ]
}
