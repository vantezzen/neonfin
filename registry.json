{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "neonfin",
  "homepage": "https://pay.vantezzen.io",
  "items": [
    {
      "name": "neonfin-client",
      "type": "registry:lib",
      "title": "neonFin client",
      "description": "Zero-dependency typed client for the neonFin API (credits, checkout, credit-code storage).",
      "files": [
        {
          "path": "registry/neonfin/lib/neonfin/index.ts",
          "type": "registry:lib",
          "target": "lib/neonfin/index.ts"
        }
      ]
    },
    {
      "name": "neonfin-server",
      "type": "registry:lib",
      "title": "neonFin server client",
      "description": "Zero-dependency server-only client for external-auth apps: get-or-create wallets by your user id and grant credits with a secret key.",
      "files": [
        {
          "path": "registry/neonfin/lib/neonfin/server.ts",
          "type": "registry:lib",
          "target": "lib/neonfin/server.ts"
        }
      ]
    },
    {
      "name": "neonfin-provider",
      "type": "registry:component",
      "title": "neonFin provider",
      "description": "NeonfinProvider context + useCredits() / useNeonfin() hooks. Required by all neonFin components.",
      "registryDependencies": ["https://pay.vantezzen.io/r/neonfin-client.json"],
      "files": [
        {
          "path": "registry/neonfin/components/neonfin/provider.tsx",
          "type": "registry:component",
          "target": "components/neonfin/provider.tsx"
        }
      ]
    },
    {
      "name": "neonfin-credits",
      "type": "registry:component",
