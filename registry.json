        "dialog",
        "button",
        "input",
        "https://pay.vantezzen.io/r/neonfin-provider.json"
      ],
      "dependencies": ["lucide-react"],
      "files": [
        {
          "path": "registry/neonfin/components/neonfin/wallet-button.tsx",
          "type": "registry:component",
          "target": "components/neonfin/wallet-button.tsx"
        },
        {
          "path": "registry/neonfin/components/neonfin/wallet-dialog.tsx",
