# Database connection. In secure deployments this can use a DB role scoped to
# provider secret rows instead of the web app's broader role.
DATABASE_URL="postgres://pay:pay@localhost:5432/pay"

# Shared bearer secret accepted by this provider service.
PAY_PROVIDER_SERVICE_SECRET=""
PAY_PROVIDER_SERVICE_PORT="3001"

# Local encryption backend. Use this for simple self-hosting.
PAY_SECRETS_PROVIDER="env"
# 32-byte key, base64-encoded. Generate with: openssl rand -base64 32
PAY_ENCRYPTION_KEY=""

# Vault Transit backend. Use when PAY_SECRETS_PROVIDER="vault".
VAULT_ADDR="http://127.0.0.1:8200"
VAULT_TOKEN=""
VAULT_TRANSIT_MOUNT="transit"
VAULT_TRANSIT_KEY="pay-provider-secrets"
