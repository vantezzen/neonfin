# Database (driver-agnostic Postgres connection string)
# Local docker-compose default shown below; swap for a Neon/Supabase URL in prod.
DATABASE_URL="postgres://pay:pay@localhost:5432/pay"

# Provider service access. Provider-only secrets live in services/provider/.env.
# Shared secret used by the web app to call the internal provider service.
PAY_PROVIDER_SERVICE_SECRET=""
# Internal provider-service URL. Local default when running `bun run dev`.
PAY_PROVIDER_SERVICE_URL="http://localhost:3001"
# Signs better-auth sessions. Generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=""

# App
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Set to "false" on a private instance to disable developer signups.
# (The first account is always allowed, to bootstrap an empty database.)
PAY_ALLOW_SIGNUPS="true"

# Example Page
# If you want to use the example page (/example), fill these with a local example project key
NEXT_PUBLIC_EXAMPLE_PAY_KEY=pay_pk_...
NEXT_PUBLIC_EXAMPLE_PAY_URL="http://localhost:3000"
